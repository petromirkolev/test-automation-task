{
  "name": "test-automation-task",
  "version": "1.0.0",
  "description": "Demo web application test automation task",
  "main": "index.js",
  "scripts": {
    "setup": "npm install && npx playwright install && cp .env.example .env",
    "test": "playwright test",
    "test:required": "playwright test -g @required",
    "test:ui": "playwright test --ui",
    "test:headed": "playwright test --headed",
    "test:debug": "playwright test --debug",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix"
  },
